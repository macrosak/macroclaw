# Environment variables override settings from ~/.macroclaw/settings.json.
# On first run without a settings file, an interactive setup wizard runs instead.
# These env vars are optional if you have a settings file.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=<from @BotFather>
# Numeric chat ID authorized to use the bot
AUTHORIZED_CHAT_ID=<numeric chat ID>
# Claude model to use (haiku, sonnet, opus)
MODEL=sonnet
# Path to the agent workspace directory
WORKSPACE=~/.macroclaw-workspace
# OpenAI API key for Whisper speech-to-text (optional, enables voice messages)
# OPENAI_API_KEY=<from platform.openai.com>
# Pinorama log server URL (optional)
# PINORAMA_URL=http://localhost:6200/pinorama
# Log level: debug, info, warn, error (optional, defaults to info)
# LOG_LEVEL=debug
