{
  "name": "macroclaw",
  "version": "0.1.0",
  "description": "Telegram-to-Claude-Code bridge",
  "type": "module",
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun run --watch src/main.ts",
    "lint": "biome check",
    "test": "bun test --coverage",
    "test:coverage": "bun test --coverage",
    "sync-skills": "bun run scripts/sync-skills.ts",
    "claude": "set -a && . ./.env && set +a && cd ${WORKSPACE:-~/.macroclaw-workspace} && claude --resume $SESSION_ID --model ${MODEL:-sonnet}"
  },
  "dependencies": {
    "cron-parser": "^5.5.0",
    "grammy": "^1.39.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "bun-types": "^1.3.10"
  }
}
