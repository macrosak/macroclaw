{
  "name": "macroclaw",
  "version": "0.1.0",
  "description": "Telegram-to-Claude-Code bridge",
  "type": "module",
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun run --watch src/main.ts",
    "check": "tsc --noEmit && biome check && bun test --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --fix --unsafe",
    "test": "bun test --coverage",
    "sync-skills": "bun run scripts/sync-skills.ts",
    "claude": "set -a && . ./.env && set +a && cd ${WORKSPACE:-~/.macroclaw-workspace} && claude --resume $(node -p \"require('$HOME/.macroclaw/settings.json').sessionId\") --model ${MODEL:-sonnet}"
  },
  "dependencies": {
    "cron-parser": "^5.5.0",
    "grammy": "^1.39.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "bun-types": "^1.3.10",
    "typescript": "^5.9.3"
  }
}
